# ---------------------------------------------------------------------------
# Optional overrides for docker-compose.
#
# The stack runs out of the box with safe development defaults baked into
# docker-compose.yml — you do NOT need to create a .env file to run it.
# Copy this file to `.env` only if you want to override any value.
# ---------------------------------------------------------------------------

# PostgreSQL
DB_USER=recruiter
DB_PASSWORD=recruiter_dev_password
DB_NAME=recruitment_portal

# Backend
JWT_SECRET=change-me-in-production-9f8e7d6c5b4a
JWT_EXPIRES_IN=1d

# Host ports
UI_PORT=3000
API_PORT=5000
